# Your Open WebUI instance URL (e.g. http://localhost:3000)
UPSTREAM_BASE=http://localhost:3000

# Your Open WebUI login — used to sign in and auto-refresh the JWT
OWUI_EMAIL=you@example.com
OWUI_PASSWORD=

# Alternative to email/password: paste a JWT directly (expires ~28 days)
# OWUI_TOKEN=

# Default model when the request doesn't specify "model"
DEFAULT_MODEL=

# Host port (container listens on 5002)
PROXY_PORT=5002

# Optional: require "Authorization: Bearer <key>" from clients
PROXY_API_KEY=

# Show the model's thinking as <think>…</think> inside the reply (1 = on).
# Set 0 only if your client natively renders the `reasoning_content` field.
REASONING_TO_CONTENT=1
